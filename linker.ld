/* linker.ld */
ENTRY(_start)

SECTIONS {
    . = 1M;
    
    .text : {
        KEEP(*(.multiboot))
        *(.text)
    }
    
    .rodata BLOCK(4K) : ALIGN(4K) {
        *(.rodata)
    }
    
    .data BLOCK(4K) : ALIGN(4K) {
        *(.data)
    }
    
    .bss BLOCK(4K) : ALIGN(4K) {
        *(COMMON)
        *(.bss)
    }
}